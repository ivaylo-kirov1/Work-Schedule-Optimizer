# hostnames db/redis = compose service names

# database (psycopg3 dialect required: postgresql+psycopg://) 
DATABASE_URL=postgresql+psycopg://scheduser:schedpass@db:5432/schedules

# keep in sync with DATABASE_URL.
POSTGRES_USER=scheduser
POSTGRES_PASSWORD=schedpass
POSTGRES_DB=schedules

# redis (Celery broker + result backend)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# security 
SECRET_KEY=change-me-generate-a-real-32+char-secret-key
JWT_EXPIRE_MINUTES=480

# CORS 
CORS_ORIGINS=http://localhost:8080

# initial manager  
INITIAL_MANAGER_EMAIL=manager@example.com
INITIAL_MANAGER_PASSWORD=CHANGE_ME_BEFORE_FIRST_RUN

# frontend API base URL
VITE_API_BASE_URL=
